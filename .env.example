# Server Configuration
PORT=3000
NODE_ENV=development

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=github_analyzer

# GitHub API Configuration
# Optional: Add a GitHub Personal Access Token to increase API rate limits
# Without token: 60 requests/hour | With token: 5000 requests/hour
# Generate at: https://github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=

# Pagination defaults
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=50
